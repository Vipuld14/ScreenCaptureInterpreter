# Secrets — never commit
.env

# Virtual environment
.venv/
venv/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# OS / editor
.DS_Store
.idea/
.vscode/

# Captured images (scratch)
captures/
*.png
*.jpg

# Cowork / Claude cache
.claude/

# Word temp lock files
~$*

# Generated reports / source files (may contain sensitive screen text)
reports/

# Local test inputs — keep the folders + READMEs, ignore screenshots/fixtures
tests/inbox/*
!tests/inbox/README.md
tests/real/*
!tests/real/README.md
